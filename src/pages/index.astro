---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main>
		<h1>sekayu122</h1>
		<p>電子工作、3DCG、画像処理、mac mini自動化の記録。</p>
	</main>
</Layout>

<style>
	main {
		display: grid;
		min-height: 100vh;
		place-content: center;
		padding: 2rem;
		font-family: system-ui, sans-serif;
	}

	h1 {
		margin: 0 0 0.5rem;
		font-size: clamp(2rem, 8vw, 5rem);
	}

	p {
		margin: 0;
		font-size: 1.125rem;
		line-height: 1.7;
	}
</style>
